# Lumiere Configuration
# Copy this to .env and fill in your values

# Balloonerism API base URL (TMDB proxy)
BALLOONERISM_API_URL=https://api.balloonerismm.workers.dev

# Rotten Tomatoes scraper settings
# RT_HEADLESS=true                    # Use browserless scraping (no API key needed)
RT_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36

# Default scan parameters
DEFAULT_MIN_RATING=6.5
DEFAULT_MAX_PAGES=500
DEFAULT_LANGUAGE=                    # Leave blank for all languages
